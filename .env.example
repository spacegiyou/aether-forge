# xAI / Grok (server-only — never expose to the client)
# Verify current model names at https://docs.x.ai before deploying:
#   grok-4.3              — primary chat (OAuth subscription surface)
#   grok-build-0.1        — agentic coding (API key path)
#   grok-imagine-image-quality — POST /v1/images/generations
XAI_API_KEY=xai-...
GROK_TEXT_MODEL=grok-4.3
GROK_FAST_MODEL=grok-build-0.1
GROK_IMAGE_MODEL=grok-imagine-image-quality

# Credential mode: auto (default) prefers local OAuth, then XAI_API_KEY, then mock
AI_MODE=auto

# Used by Next metadata for Open Graph image URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional API base override (rarely needed)
# XAI_BASE_URL=https://api.x.ai/v1

# Persistence (Phase B)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional
X_API_BEARER_TOKEN=
